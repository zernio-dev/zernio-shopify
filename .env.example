# Shopify app credentials (from Shopify Partner Dashboard)
SHOPIFY_API_KEY=your_shopify_app_api_key
SHOPIFY_API_SECRET=your_shopify_app_secret
SCOPES=read_products

# Database (PostgreSQL - e.g. Neon via Vercel Marketplace)
DATABASE_URL=postgresql://user:password@host/dbname

# Encryption key for storing Zernio API keys (64-char hex = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_character_hex_string_here

# App URL (your deployed domain)
SHOPIFY_APP_URL=https://store.zernio.com

# Optional: custom shop domain (for Shopify Plus stores with custom domains)
# SHOP_CUSTOM_DOMAIN=my-custom-domain.com
